# Local web app settings
SECRET_KEY=change-this-to-a-long-random-secret
DATABASE_URL=sqlite:///./crm.db

# AWS Bedrock settings (used by crm-web/services/bedrock_service.py)
AWS_REGION=us-east-2
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6
# If your model requires an inference profile, set its ID or full ARN here.
# Example ARN: arn:aws:bedrock:us-east-2:123456789012:inference-profile/your-profile-id
BEDROCK_INFERENCE_PROFILE_ID=

# Preferred local auth method for AWS SDK:
# 1) Use AWS_PROFILE with credentials stored by `aws configure --profile <name>`
# 2) Or leave AWS_PROFILE empty and rely on your default profile
# 3) Or set AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY directly (not recommended)
AWS_PROFILE=default
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
